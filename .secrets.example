# ---------------------------------------------------------------------
# GitHub Actions local secrets for nektos/act
# ---------------------------------------------------------------------
# Copy this file to .secrets and fill in the values:
#   cp .secrets.example .secrets
#
# Do NOT commit .secrets to the repository — it is already in .gitignore.
#
# The default local test suite (lint + actionlint + tests) does
# NOT require any secrets. You only need this file to test the
# push_to_registry or build jobs locally.
# ---------------------------------------------------------------------

# GitHub token — used by push_to_registry (docker login to ghcr.io)
# and build (Netlify deploy comment). For local testing, a classic
# personal access token with 'write:packages' scope is enough.
GITHUB_TOKEN=ghp_replace_with_your_token

# Netlify credentials — only needed for the build + deploy job.
# Get them from the Netlify dashboard (User Settings > Applications).
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
