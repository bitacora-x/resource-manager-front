# ---------------------------------------------------------------------
# Environment variables for nektos/act local execution
# ---------------------------------------------------------------------
# Copy this file to .env.act and customize for your machine:
#   cp .env.act.example .env.act
#
# These variables are injected into every job at runtime.
# Do NOT commit .env.act to the repository.
# ---------------------------------------------------------------------

# Add any environment variables your jobs need here.
# Example:
#   API_BASE_URL=http://localhost:8080
