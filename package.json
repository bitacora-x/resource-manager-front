{
  "name": "resource-maganer-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test": "vitest",
    "preview": "vite preview",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit && eslint .",
    "pre-commit": "pnpm run format:check && pnpm run lint && vitest --run"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.2.8"
  }
}
